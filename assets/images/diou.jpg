  right: 0;
  font-size: 0;
  width: 0vh;
  height: 0vh;
  visibility: none;
}

#rewid-f.modern iframe {
  border-radius: 5px;
}

#rewid-f:dir(rtl) {
  right: auto;
  left: 0;
}

