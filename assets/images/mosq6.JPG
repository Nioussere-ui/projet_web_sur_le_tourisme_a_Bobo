mcvZnIvR3JhbmRfTW9zcXVlX29mX0JvYm8tRGlvdWxhc3Nv&amp;ntb=1" h="ID=SERP.5744,5030.1"><span class="gs_cit_txt" data-sups="1,2,3,4" data-hover-id="1" tabindex="-1"><span class="gs_tkn">La </span><span class="gs_tkn"></span><strong><span class="gs_tkn">Grande </span><span class="gs_tkn">Mosquée </span><span class="gs_tkn">de </span><span class="gs_tkn">Bobo-Dioulasso</span></strong><span class="gs_tkn"> </span><span class="gs_tkn">est </span><span class="gs_tkn">un </span><span class="gs_tkn">monument </span><span class="gs_tkn">religieux </span><span class="gs_tkn">emblématique </span><span class="gs_tkn">du </span><span class="gs_tkn">Burkina </span><span class="gs_tkn">Faso, </span><span class="gs_tkn">construit </span><span class="gs_tkn">vers </span><span class="gs_tkn"></span><strong><span class="gs_tkn">1880</span></strong><span class="gs_tkn"> </span><span class="gs_tkn">sous </span><span class="gs_tkn">l'impulsion </span><span class="gs_tkn">de </span><span class="gs_tkn">l'imam </span><span class="gs_tkn"></span><strong><span class="gs_tkn">Almamy </span><span class="gs_tkn">Sidiki </span><span class="gs_tkn">Sanou</span></strong><span class="gs_tkn">. </span><span class="gs_tkn">Cette </span><span class="gs_tkn">mosquée, </span><span class="gs_tkn">qui </span><span class="gs_tkn">est </span><span class="gs_tkn">un </span><span class="gs_tkn">chef-d'œuvre </span><span class="gs_tkn">de </span><span class="gs_tkn">l'architecture </span><span class="gs_tkn">soudano-sahélienne, </span><span class="gs_tkn">se </span><span class="gs_tkn">distingue </span><span class="gs_tkn">par </span><span class="gs_tkn">ses </span><span class="gs_tkn"></span><strong><span class="gs_tkn">minarets </span><span class="gs_tkn">en </span><span class="gs_tkn">banco</span></strong><span class="gs_tkn"> </span><span class="gs_tkn">et </span><span class="gs_tkn">ses </span><span class="gs_tkn"></span><strong><span class="gs_tkn">poutres </span><span class="gs_tkn">en </span><span class="gs_tkn">bois</span></strong><span class="gs_tkn">, </span><span class="gs_tkn">reflétant </span><span class="gs_tkn">le </span><span class="gs_tkn">savoir-faire </span><span class="gs_tkn">local. </span><span class="gs_tkn">Elle </span><span class="gs_tkn">a </span><span class="gs_tkn">été </span><span class="gs_tkn">construite </span><span class="gs_tkn">dans </span><span class="gs_tkn">un </span><span class="gs_tkn">contexte </span><span class="gs_tkn">de </span><span class="gs_tkn">résistance </span><span class="gs_tkn">face </span><span class="gs_tkn">aux </span><span class="gs_tkn">guerres </span><span class="gs_tkn">et </span><span class="gs_tkn">est </span><span class="gs_tkn">devenue </span><span class="gs_tkn">un </span><span class="gs_tkn">symbole </span><span class="gs_tkn">de </span><span class="gs_tkn">la </span><span class="gs_tkn">communauté </span><span class="gs_tkn">locale. </span><span class="gs_tkn">La </span><span class="gs_tkn">mosquée </span><span class="gs_tkn">est </span><span class="gs_tkn">également </span><span class="gs_tkn">un </span><span class="gs_tkn">lieu </span><span class="gs_tkn">de </span><span class="gs_tkn">prière </span><span class="gs_tkn">et </span><span class="gs_tkn">d'enseignement, </span><span class="gs_tkn">attirant </span><span class="gs_tkn">des </span><span class="gs_tkn">visiteurs </span><span class="gs_tkn">pour </span><span class="gs_tkn">découvrir </span><span class="gs_tkn">son </span><span class="gs_tkn">architecture </span><span class="gs_tkn">unique </span><span class="gs_tkn">et </span><span class="gs_tkn">son </span><span class="gs_tkn">histoire </span><span class="gs_tkn">riche. </span><span class="gs_tkn"></span></span></a><div class="gs_tkn gs_sup_cit gs_sup_cit1" data-priority="2" data-hover-id="1" tabindex="0"><a aria-label="Afficher la source sur wikiland.org" target="_blank" href="https://www.bing.com/ck/a?!&amp;&amp;p=e79990b0028472350172b512ea83c3dce1b253fd1c91e277aeb6bfb0eedb8c93JmltdHM9MTc4MDA5OT